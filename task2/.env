ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg
MAX_UPLOAD_FILES=3
UPLOAD_FOLDER=storage/uploads

LOG_FOLDER=logs
LOG_FILE=app.log
LOG_LEVEL=INFO

EXTRACTED_TEXT_FOLDER=storage/extracted_text

CHUNK_SIZE=500
CHUNK_OVERLAP=100

EMBEDDING_MODEL=all-MiniLM-L6-v2

MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=chat_engine