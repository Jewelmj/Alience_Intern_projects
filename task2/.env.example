# Upload
ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg
MAX_UPLOAD_FILES=3
MAX_PDF_PAGES=5

UPLOAD_FOLDER=storage/uploads
EXTRACTED_TEXT_FOLDER=storage/extracted_text

# Logging
LOG_FOLDER=logs
LOG_FILE=app.log
LOG_LEVEL=INFO

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# DB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=chat_engine

CHROMA_DB_PATH=storage/chromadb
CHROMA_COLLECTION=documents

# Retrieval

RETRIEVAL_TOP_K=5
RELEVANCE_MAX_DISTANCE=2.0
NOT_FOUND_MESSAGE=I could not find information about that in the uploaded documents.

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# UI
API_BASE_URL=http://127.0.0.1:8000